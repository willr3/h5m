      "operation": "value => {\n    var sut = []\n    var test_date = new Date(value[\"start_time\"]);\n    sut.push(value[\"rhivos_target\"]);\n    sut.push(value[\"rhivos_os_id\"]);\n    sut.push(value[\"rhivos_mode\"]);\n    sut.push(value[\"rhivos_build\"]);\n    sut.push(`${String(test_date.getFullYear()).padStart(4, '0')}-${String(test_date.getMonth() + 1).padStart(2, '0')}-${String(test_date.getDate()).padStart(2, '0')} ${String(test_date.getHours()).padStart(2, '0')}:${String(test_date.getMinutes()).padStart(2, '0')}:${String(test_date.getSeconds()).padStart(2, '0')}`);\n    return sut.join(' ')\n}",
